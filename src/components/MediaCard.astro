---
import PhotoCarousel from './PhotoCarousel.astro';

export interface Props {
  type: 'video' | 'image' | 'pdf';
  image?: string;
  photos?: string[];
  youtubeId?: string;
  src?: string;
  pdfUrl?: string;
  playerId: string;
  title: string;
  kicker: string;
  description: string;
  details?: string[];
  link?: string;
  linkLabel?: string;
}

const { type, image, photos, youtubeId, src, pdfUrl, playerId, title, kicker, description, details, link, linkLabel } = Astro.props;
const origin = Astro.url.origin;
---

<article class="media-card">
  <div class="media-frame">
    {type === 'video' && youtubeId && (
      <div class="plyr__video-embed" id={playerId}>
        <iframe
          src={`https://www.youtube.com/embed/${youtubeId}?origin=${origin}&iv_load_policy=3&modestbranding=1&playsinline=1&rel=0`}
          allowfullscreen
          allow="autoplay; encrypted-media"
          title={title}
        ></iframe>
      </div>
    )}
    {type === 'video' && src && (
      <video class="plyr__video-embed" id={playerId} playsinline controls>
        <source src={src} type={`video/${src.split('.').pop()}`} />
      </video>
    )}
    {type === 'pdf' && pdfUrl && (
      <div class="pdf-viewer" data-pdf-src={pdfUrl}></div>
    )}
    {photos ? (
      <PhotoCarousel photos={photos} />
    ) : (
      !youtubeId && !src && image && <img src={image} alt="" loading="lazy" />
    )}
  </div>
  <div class="media-copy">
    <p class="section-kicker">{kicker}</p>
    <h2>{title}</h2>
    <div class="expand-content">
      <p>{description}</p>
      {details && details.length > 0 && details.map((detail) => <p class="detail">{detail}</p>)}
    </div>
    <div class="actions-row">
      {details && details.length > 0 && (
        <label class="more-btn" aria-label="Toggle details">
          <input type="checkbox" class="more-toggle" hidden />
          <span class="more-text">[more]</span>
          <span class="close-text">[close]</span>
        </label>
      )}
      {link && <a href={link} target="_blank" rel="noopener noreferrer">{linkLabel || 'Open project'}</a>}
    </div>
  </div>
</article>

<style>
  .media-card {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
    gap: clamp(1rem, 4vw, 3rem);
    align-items: start;
    padding-top: clamp(1rem, 3vw, 2rem);
    border-top: 1px solid var(--line);
  }

  .media-frame {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--bg);
  }

  .media-frame img {
    width: 100%;
    display: block;
  }

  .pdf-viewer {
    width: 100%;
    height: 500px;
    border: none;
  }

  .media-copy h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1;
  }

  .media-copy > p:not(.section-kicker) {
    color: var(--muted);
    margin-bottom: 0;
  }

  .expand-content {
    overflow: hidden;
    max-height: fit-content;
    transition: max-height 0.3s ease;
    margin: 0.5rem 0;
    padding-inline-end: 0.5rem;
    scrollbar-gutter: stable;
  }

  .expand-content .detail {
    display: none;
  }

  .media-copy:has(.more-toggle:checked) .expand-content {
    max-height: 15rem;
    overflow: hidden auto;
  }

  .media-copy:has(.more-toggle:checked) .expand-content::-webkit-scrollbar {
    width: 6px;
  }

  .media-copy:has(.more-toggle:checked) .expand-content::-webkit-scrollbar-track {
    background: transparent;
  }

  .media-copy:has(.more-toggle:checked) .expand-content::-webkit-scrollbar-thumb {
    background: var(--line);
    border-radius: 3px;
  }

  .media-copy:has(.more-toggle:checked) .expand-content::-webkit-scrollbar-button {
    display: none;
    width: 0;
    height: 0;
  }

  .media-copy:has(.more-toggle:checked) .expand-content::-webkit-scrollbar-corner {
    background: transparent;
  }

  .media-copy:has(.more-toggle:checked) .expand-content .detail {
    display: block;
  }

  .close-text {
    display: none;
  }

  .media-copy:has(.more-toggle:checked) .more-text {
    display: none;
  }

  .media-copy:has(.more-toggle:checked) .close-text {
    display: inline;
  }

  .expand-content p {
    color: var(--muted);
  }

  .actions-row {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .actions-row button,
  .actions-row .more-btn,
  .media-copy a {
    background: none;
    border: none;
    cursor: pointer;
    user-select: none;
    color: var(--accent);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.35em;
    padding: 0;
    font-family: inherit;
  }

  @media (max-width: 860px) {
    .media-card {
      grid-template-columns: 1fr;
    }
  }
</style>



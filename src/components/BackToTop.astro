<a class="back-to-top" href="#" aria-label="Back to top">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13 8L8 3l-5 5" stroke="currentColor" stroke-width="1.5"/></svg>
</a>

<style>
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(18px);
    color: var(--muted);
    text-decoration: none;
    opacity: 0;
    pointer-events: none;
  }

  .back-to-top.is-visible {
    opacity: 1;
    pointer-events: auto;
    transition: opacity 300ms ease, color 180ms ease;
  }

  .back-to-top:hover {
    color: var(--accent);
  }
</style>

<script>
  const el = document.querySelector('.back-to-top');
  if (el) {
    let ticking = false;
    document.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          el.classList.toggle('is-visible', window.scrollY > 300);
          ticking = false;
        });
        ticking = true;
      }
    });
    el.addEventListener('click', (e) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

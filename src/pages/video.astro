---
import Layout from '../layouts/Layout.astro';
import MediaCard from '../components/MediaCard.astro';
import { videoProjects } from '../data/portfolio';
---

<Layout title="Video" description="Narrative, documentary, and experimental video works." currentPath="/video/" mainClass="page-shell video-page">
    <h2 class="section-kicker page-title">Video</h2>
    <section class="video-list" aria-label="Video projects">
      {videoProjects.map((project, index) => (
        <MediaCard
          type="video"
          youtubeId={project.youtubeId}
          playerId={`player-${index}`}
          title={project.title}
          kicker={project.role}
          description={project.intro}
          details={project.details}
          link={project.link}
          linkLabel="Open on YouTube"
        />
      ))}
    </section>
</Layout>

<style>
  .video-page {
    padding-bottom: 3rem;
  }

  .page-title {
    padding: 1rem 0;
    font-weight: normal;
  }

  .video-list {
    display: grid;
    gap: 2rem;
  }

  :global(.plyr) {
    --plyr-color-main: var(--accent);
    height: 100%;
  }
</style>

<link is:inline rel="stylesheet" href="https://cdn.plyr.io/3.8.4/plyr.css" />
<script is:inline data-astro-rerun src="https://cdn.plyr.io/3.8.4/plyr.js"></script>
<script is:inline data-astro-rerun>
  document.querySelectorAll('.plyr__video-embed, .plyr-video').forEach(function (player) {
    new Plyr(player, {
      controls: ['play-large', 'play', 'progress', 'current-time', 'mute', 'volume', 'fullscreen'],
    });
  });
</script>

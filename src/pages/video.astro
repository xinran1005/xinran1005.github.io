---
import 'plyr/dist/plyr.css';
import Layout from '../layouts/Layout.astro';
import MediaCard from '../components/MediaCard.astro';
import { videoProjects } from '../data/portfolio';
---

<Layout title="Video" description="Narrative, documentary, and experimental video works." currentPath="/video/">
    <h2 class="section-kicker page-title">Video</h2>
    <section class="video-list" aria-label="Video projects">
      {videoProjects.map((project, index) => (
        <MediaCard
          type="video"
          youtubeId={project.youtubeId}
          playerId={`player-${index}`}
          title={project.title}
          kicker={project.role}
          description={project.intro}
          details={project.details}
          link={project.link}
          linkLabel="Open on YouTube"
        />
      ))}
    </section>
</Layout>

<style>
  .page-title {
    padding: 1rem 0;
    font-weight: normal;
  }

  .video-list {
    display: grid;
    gap: 2rem;
  }

  :global(.plyr) {
    --plyr-color-main: var(--accent);
    height: 100%;
  }
</style>

<script>
  import Plyr from 'plyr';

  document.querySelectorAll('.plyr__video-embed').forEach((player) => {
    new Plyr(player, {
      controls: ['play-large', 'play', 'progress', 'current-time', 'mute', 'volume', 'fullscreen'],
    });
  });
</script>

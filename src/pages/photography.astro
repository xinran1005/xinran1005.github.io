---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import { photographyAlbums, type PhotoAlbum } from '../data/portfolio';

const photosDir = path.join(process.cwd(), 'public', 'Photography');
const photosUrl = '/Photography';

interface ResolvedAlbum {
  id: string;
  title: string;
  description: string;
  cover: string;
  photos: string[];
  showName?: boolean;
  children?: ResolvedAlbum[];
}

function resolveAlbum(album: PhotoAlbum): ResolvedAlbum | null {
  if (album.albumFolder) {
    const dir = path.join(photosDir, album.albumFolder);
    if (!fs.existsSync(dir)) return null;
    const files = fs
      .readdirSync(dir)
      .filter((f) => /\.(jpe?g|png|webp|gif)$/i.test(f))
      .sort();
    if (files.length === 0) return null;
    return {
      id: album.id,
      title: album.title,
      description: album.description,
      cover: `${photosUrl}/${album.albumFolder}/${files[0]}`,
      photos: files.map((f) => `${photosUrl}/${album.albumFolder}/${f}`),
      ...(album.showName && { showName: true }),
    };
  }

  if (album.children) {
    const resolvedChildren = album.children
      .map(resolveAlbum)
      .filter((c): c is ResolvedAlbum => c !== null);
    if (resolvedChildren.length === 0) return null;
    return {
      id: album.id,
      title: album.title,
      description: album.description,
      cover: resolvedChildren[0].cover,
      photos: [],
      ...(album.showName && { showName: true }),
      children: resolvedChildren,
    };
  }

  return null;
}

const albums: ResolvedAlbum[] = photographyAlbums
  .map(resolveAlbum)
  .filter((a): a is ResolvedAlbum => a !== null);
---

<Layout title="Photography" description="Photography works organized into themed albums." currentPath="/photography/">
    <section class="page-title" aria-labelledby="photography-title">
      <p class="section-kicker">Photography</p>
    </section>

    <section class="albums" aria-label="Photography albums">
      {albums.map((album) => (
        <a class="album-card" href={`#album-${album.id}`}>
          <img src={album.cover} alt="" />
          <span class="album-info">
            <strong>{album.title}</strong>
            <small>{album.description}</small>
          </span>
        </a>
      ))}
    </section>

    {albums.map((album) =>
      album.children ? (
        <div class="parent-album" id={`album-${album.id}`}>
          <div class="parent-album-heading">
            <h2 class="parent-album-title">{album.title}</h2>
            <p>{album.description}</p>
          </div>
          <nav class="sub-albums" aria-label="Sub-albums">
            {album.children.map((child) => (
              <a class="album-card sub" href={`#album-${child.id}`}>
                <img src={child.cover} alt="" />
                <span class="album-info">
                  <strong>{child.title}</strong>
                  <small>{child.description}</small>
                </span>
              </a>
            ))}
          </nav>
          {album.children.map((child) => (
            <PhotoGallery album={{ ...child, showName: album.showName || child.showName }} />
          ))}
        </div>
      ) : (
        <PhotoGallery album={album} />
      )
    )}
</Layout>

<style>
  .page-title {
    padding: 1rem 0;
  }

  .albums {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .album-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 340px;
    color: var(--paper);
    overflow: hidden;
    position: relative;
    text-decoration: none;
    border: 1px solid var(--line);
  }

  .album-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) brightness(0.72);
    transition: transform 400ms ease, filter 300ms ease;
  }

  .album-card .album-info {
    position: relative;
    width: 100%;
    text-align: end;
    display: flex;
    align-items: flex-end;
    flex-direction: column;
    padding: 1.4rem;
  }

  .album-card:hover img,
  .album-card:focus-visible img {
    filter: grayscale(0.35) brightness(0.75);
    transform: scale(1.03);
  }

  .album-card strong {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 0.95;
    overflow-wrap: break-word;
  }

  .album-card small {
    max-width: 28rem;
    color: rgba(255, 253, 250, 0.82);
    font-size: 0.95rem;
    overflow-wrap: break-word;
  }

  .parent-album {
    padding-top: 2rem;
  }

  .sub-albums {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .parent-album-heading {
    margin-bottom: 2rem;
  }

  .parent-album-title {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 400;
  }

  .parent-album-heading p {
    margin: 0.6rem 0 0;
    color: var(--muted);
  }

  @media (max-width: 680px) {
    .albums,
    .sub-albums {
      grid-template-columns: 1fr;
    }

    .album-card {
      min-height: 10rem;
      text-shadow:
        0 0 8px rgba(0,0,0,0.8),
        0 0 2px rgba(0,0,0,0.9);
    }

    .album-card img{
      filter: grayscale(0);
    }
  }
</style>

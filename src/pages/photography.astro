---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import { photographyAlbums } from '../data/portfolio';

const photosDir = path.join(process.cwd(), 'public', 'photos');

interface AlbumWithPhotos {
  id: string;
  title: string;
  href: string;
  description: string;
  cover: string;
  photos: string[];
}

const albums: AlbumWithPhotos[] = photographyAlbums
  .map((album) => {
    const dir = path.join(photosDir, album.albumFolder);
    if (!fs.existsSync(dir)) return null;
    const files = fs
      .readdirSync(dir)
      .filter((f) => /\.(jpe?g|png|webp|gif)$/i.test(f))
      .sort();
    if (files.length === 0) return null;
    return {
      ...album,
      cover: `/photos/${album.albumFolder}/${files[0]}`,
      photos: files.map((f) => `/photos/${album.albumFolder}/${f}`),
    };
  })
  .filter((a): a is AlbumWithPhotos => a !== null);
---

<Layout title="Photography" description="Photography works organized into themed albums." currentPath="/photography/">
  <main class="page-shell">
    <section class="page-title" aria-labelledby="photography-title">
      <p class="section-kicker">Photography</p>
    </section>

    <section class="albums" aria-label="Photography albums">
      {albums.map((album) => (
        <a class="album-card" href={album.href}>
          <img src={album.cover} alt="" />
          <span class="album-info">
            <strong>{album.title}</strong>
            <small>{album.description}</small>
          </span>
        </a>
      ))}
    </section>

    {albums.map((album) => (
      <PhotoGallery album={album} />
    ))}
  </main>
</Layout>

<style>
  .page-title {
    padding: 1rem 0;
  }

  .albums {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .album-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 340px;
    color: var(--paper);
    overflow: hidden;
    position: relative;
    text-decoration: none;
    border: 1px solid var(--line);
  }

  .album-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) brightness(0.72);
    transition: transform 400ms ease, filter 300ms ease;
  }

  .album-card .album-info {
    position: relative;
    width: 100%;
    text-align: end;
    display: flex;
    align-items: flex-end;
    flex-direction: column;
    padding: 1.4rem;
  }

  .album-card:hover img,
  .album-card:focus-visible img {
    filter: grayscale(0.35) brightness(0.75);
    transform: scale(1.03);
  }

  .album-card strong {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 0.95;
    overflow-wrap: break-word;
  }

  .album-card small {
    max-width: 28rem;
    color: rgba(255, 253, 250, 0.82);
    font-size: 0.95rem;
    overflow-wrap: break-word;
  }

  @media (max-width: 680px) {
    .albums {
      grid-template-columns: 1fr;
    }

    .album-card {
      min-height: 10rem;
      text-shadow:
        0 0 8px rgba(0,0,0,0.8),
        0 0 2px rgba(0,0,0,0.9);
    }

    .album-card img{
      filter: grayscale(0);
    }
  }
</style>

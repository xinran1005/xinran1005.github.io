---
import 'plyr/dist/plyr.css';
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import MediaCard from '../components/MediaCard.astro';
import { designSections } from '../data/portfolio';

const photosDir = path.join(process.cwd(), 'public', 'photos');

interface DesignProject {
  title: string;
  image?: string;
  albumFolder?: string;
  youtubeId?: string;
  src?: string;
  status: string;
  description: string;
  details?: string[];
  link?: string;
  linkLabel?: string;
  photos?: string[];
}

function resolveProject(project: DesignProject): DesignProject {
  if (project.albumFolder) {
    const dir = path.join(photosDir, project.albumFolder);
    if (fs.existsSync(dir)) {
      const files = fs
        .readdirSync(dir)
        .filter((f) => /\.(jpe?g|png|webp|gif)$/i.test(f))
        .sort()
        .map((f) => `/photos/${project.albumFolder}/${f}`);
      if (files.length > 0) {
        return { ...project, photos: files };
      }
    }
  }
  return project;
}
---

<Layout title="Design" description="UI/UX and graphic design works organized by discipline." currentPath="/design/">
    <section class="page-title" aria-labelledby="design-title">
      <p class="section-kicker">Design</p>
    </section>

    <div class="design-sections">
      {designSections.map((section) => (
        <section class="design-section">
          <div class="section-heading">
            <p class="section-kicker">{section.title}</p>
            <h2>{section.description}</h2>
          </div>

          <div class="design-list">
            {section.projects.map((project, index) => {
              const p = resolveProject(project);
              return (
                <MediaCard
                  type={p.youtubeId || p.src ? 'video' : 'image'}
                  image={p.image}
                  photos={p.photos}
                  youtubeId={p.youtubeId}
                  src={p.src}
                  playerId={`design-${index}`}
                  title={p.title}
                  kicker={p.status}
                  description={p.description}
                  details={p.details}
                  link={p.link}
                  linkLabel={p.linkLabel}
                />
              );
            })}
          </div>
        </section>
      ))}
    </div>
</Layout>

<style>
  .page-title {
    padding: 1rem 0;
  }

  .design-sections {
    display: grid;
    gap: clamp(3rem, 7vw, 6rem);
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }

  .design-section {
    display: grid;
    gap: 1.4rem;
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(160px, 0.3fr) minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    border-top: 1px solid var(--line);
    padding-top: 1.2rem;
  }

  .section-heading h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(1.8rem, 4vw, 3.5rem);
    font-weight: 400;
    line-height: 1.05;
    text-align: end;
  }

  .design-list {
    display: grid;
    gap: 2rem;
  }

  :global(.plyr) {
    --plyr-color-main: var(--accent);
    height: 100%;
  }

  @media (max-width: 640px) {
    .section-heading {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import Plyr from 'plyr';

  document.querySelectorAll('.plyr__video-embed').forEach((player) => {
    new Plyr(player, {
      controls: ['play-large', 'play', 'progress', 'current-time', 'mute', 'volume', 'fullscreen'],
    });
  });
</script>

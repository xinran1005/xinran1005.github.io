---
import Layout from '../layouts/Layout.astro';
import { contactLinks, navItems, profile, site } from '../data/portfolio';
---

<Layout title={site.title} description={site.description}>
    <section class="intro-panel" aria-labelledby="home-title">
      <img class="avatar" src={profile.avatar} alt="Portrait of Xinran Han" />
      <p class="section-kicker">Portfolio</p>
      <h1 id="home-title">Xinran Han</h1>
      <p>{profile.intro}</p>
      <nav class="discipline-list" aria-label="Contact links">
        {contactLinks.map((link) => (
          <a
            href={link.href}
            aria-label={link.ariaLabel}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {link.label === 'LinkedIn' && <span class="contact-icon" data-icon="linkedin"></span>}
            {link.label === 'Instagram' && <span class="contact-icon" data-icon="instagram"></span>}
            {link.label === 'SoundCloud' && <span class="contact-icon" data-icon="soundcloud"></span>}
            {link.label === 'Email' && <span class="contact-icon" data-icon="mail"></span>}
            {link.label}
          </a>
        ))}
      </nav>
    </section>

    <section class="tile-field" aria-label="Image navigation">
      {navItems.map((item, index) => (
        <a
          class="tile"
          href={item.href}
          data-index={index}
          data-title={item.title}
          style={`--x: ${index === 0 ? '-12vw' : index === 1 ? '-4vw' : index === 2 ? '4vw' : '12vw'}; 
          --y: ${index === 0 ? '3vh' : index === 1 ? '-5vh' : index === 2 ? '2vh' : '-4vh'}; 
          --focus-x: ${index === 0 ? '-9vw' : index === 1 ? '-3vw' : index === 2 ? '3vw' : '9vw'}; 
          --focus-y: 0`}
        >
          <span class="tile-title">{item.title}</span>
          <img src={item.image} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
          <span class="tile-caption">{item.description}</span>
        </a>
      ))}
    </section>
</Layout>

<style>
  :global(body) {
    display: flex;
    flex-direction: column;
  }
  
  :global(.page-shell) {
    width: 100%;
    overflow-x: hidden;
    display: flex;
    flex: 1;
    position: relative;
    max-height: calc(100vh - 8rem);
  }
  
  .intro-panel {
    flex: none;
    width: 330px;
    margin: clamp(1.5rem, 4vw, 3rem) 0 0 clamp(1rem, 3vw, 2rem);
  }

  .avatar {
    width: 56px;
    aspect-ratio: 1;
    margin-bottom: 0.8rem;
    border-radius: 50%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.08);
  }

  .intro-panel h1 {
    margin: 0 0 1.1rem;
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3vw, 2.45rem);
    font-weight: 600;
    line-height: 1;
  }

  .intro-panel > p:not(.section-kicker) {
    margin: 0 0 1.2rem;
    color: var(--muted);
    font-size: clamp(0.78rem, 1.1vw, 0.92rem);
    line-height: 1.45;
  }

  .discipline-list {
    margin-top: 3rem;
    display: grid;
    justify-items: start;
    gap: 0.24rem;
  }

  .discipline-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--ink);
    font-size: clamp(0.76rem, 1vw, 0.86rem);
    letter-spacing: 0.01em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .contact-icon {
    display: inline-block;
    width: 14px;
    height: 14px;
    background-color: var(--ink);
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    -webkit-mask-size: contain;
    transition: background-color 180ms ease;
  }

  .contact-icon[data-icon="linkedin"] {
    mask-image: url(/linkedin.svg);
    -webkit-mask-image: url(/linkedin.svg);
  }

  .contact-icon[data-icon="instagram"] {
    mask-image: url(/instagram.svg);
    -webkit-mask-image: url(/instagram.svg);
  }

  .contact-icon[data-icon="soundcloud"] {
    mask-image: url(/soundcloud.svg);
    -webkit-mask-image: url(/soundcloud.svg);
  }

  .contact-icon[data-icon="mail"] {
    mask-image: url(/mail.svg);
    -webkit-mask-image: url(/mail.svg);
  }

  .discipline-list a:hover,
  .discipline-list a:focus-visible {
    color: var(--accent);
  }

  .discipline-list a:hover .contact-icon,
  .discipline-list a:focus-visible .contact-icon {
    background-color: var(--accent);
  }

  .tile-field {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .tile {
    --tile-w: clamp(92px, 9vw, 128px);
    --tile-h: clamp(92px, 9vw, 128px);
    --active-w: clamp(132px, 13vw, 180px);
    --active-h: clamp(190px, 24vw, 292px);
    --hover-w: clamp(245px, 29vw, 380px);
    --hover-h: clamp(365px, 45vw, min(580px, 65vh));
    position: relative;
    width: var(--tile-w);
    height: var(--tile-h);
    color: var(--accent);
    text-decoration: none;
    transform: translate(var(--x), var(--y));
    transition:
      width 760ms cubic-bezier(.2,.75,.2,1),
      height 760ms cubic-bezier(.2,.75,.2,1),
      transform 760ms cubic-bezier(.2,.75,.2,1),
      z-index 0ms linear 220ms;
  }

  .tile.is-active {
    width: var(--active-w);
    height: var(--active-h);
    transform: translate(var(--focus-x), var(--focus-y));
    z-index: 3;
  }

  .tile-field.is-hovering .tile.is-active {
    width: var(--hover-w);
    height: var(--hover-h);
    z-index: 5;
  }

  .tile:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 5px;
  }

  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(1) contrast(1.08) brightness(0.9);
    transition:
      filter 500ms ease,
      transform 760ms cubic-bezier(.2,.75,.2,1);
  }

  .tile.is-active img {
    filter: grayscale(0.55) contrast(1.04) brightness(0.92);
    transform: scale(1.01);
  }

  .tile-field.is-hovering .tile.is-active img {
    filter: grayscale(0.05) contrast(1.03) brightness(0.95) saturate(1.25);
  }

  .tile-title {
    position: absolute;
    left: 0;
    bottom: calc(100% + 0.35rem);
    max-width: min(70vw, var(--hover-w));
    opacity: 0;
    color: var(--accent);
    font-family: var(--sans);
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    line-height: 1;
    pointer-events: none;
    transform: translateY(0.25rem);
    transition: opacity 220ms ease, transform 220ms ease;
    white-space: nowrap;
  }

  .tile-field.is-hovering .tile.is-active .tile-title {
    opacity: 1;
    transform: translateY(0);
  }

  .tile-caption {
    position: absolute;
    left: 0;
    top: calc(100% + 0.55rem);
    width: min(34ch, var(--hover-w));
    opacity: 0;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.35;
    pointer-events: none;
    transition: opacity 220ms ease;
  }

  .tile-field.is-hovering .tile.is-active .tile-caption {
    opacity: 1;
  }

  @media (max-width: 760px) {
    .tile-field {
      flex: none;
      flex-direction: column;
      min-height: auto;
      overflow: visible;
      padding: 2rem 1rem 3rem;
    }

    .intro-panel {
      position: relative;
      top: auto;
      left: auto;
      width: auto;
      margin: 0 0 2rem;
    }

    .tile-field {
      flex: none;
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      width: 100%;
    }

    .tile {
      display: block;
      position: relative;
      transform: none !important;
      width: auto;
      min-width: 0;
      height: clamp(110px, 32.5vw, 180px);
      justify-self: stretch;
      transition: height 500ms ease;
    }

    .tile.is-active,
    .tile-field.is-hovering .tile.is-active {
      display: block;
      width: auto;
      min-width: 0;
      height: clamp(220px, 65vw, 360px);
      transform: none !important;
      justify-self: stretch;
      transition: height 500ms ease;
    }

    .tile img {
      filter: grayscale(1) contrast(1.08) brightness(0.6);
      transition: filter 500ms ease;
    }

    .tile.is-active img {
      filter: grayscale(0.55) contrast(1.04) brightness(0.92);
    }

    .tile-title {
      z-index: 2;
      opacity: 0;
      transform: none;
      bottom: auto;
      top: 0.8rem;
      left: 0.8rem;
      color: var(--paper);
      text-shadow:
        0 0 8px rgba(0,0,0,0.8),
        0 0 2px rgba(0,0,0,0.9);
      max-width: calc(100% - 1.6rem);
      font-size: 2rem;
    }

    .tile-caption {
      z-index: 2;
      opacity: 0;
      display: block;
      left: 0.8rem;
      bottom: 0.8rem;
      top: auto;
      color: var(--paper);
      text-shadow:
        0 0 8px rgba(0,0,0,0.8),
        0 0 2px rgba(0,0,0,0.9);
      transition: opacity 220ms ease;
    }

    .tile.is-active .tile-caption,
    .tile.is-active .tile-title {
      opacity: 1;
    }
  }
</style>

<script>
    var home = document.querySelector('.tile-field');
    home.dataset.init = '';

    if (home.dataset.timerId) clearInterval(Number(home.dataset.timerId));
    if (home.dataset.timeoutId) clearTimeout(Number(home.dataset.timeoutId));

    var tiles = [...home.querySelectorAll('.tile')];
    var activeIndex = -1;
    var paused = false;
    var hasStarted = false;

    function setActive(index) {
      activeIndex = index;
      tiles.forEach(function (tile, tileIndex) {
        tile.classList.toggle('is-active', tileIndex === index);
      });
    }

    function rotate() {
      if (paused || tiles.length === 0) return;
      setActive((activeIndex + 1) % tiles.length);
    }

    tiles.forEach(function (tile, index) {
      tile.addEventListener('mouseenter', function () {
        paused = true;
        home.classList.add('is-hovering');
        setActive(index);
      });
      tile.addEventListener('focus', function () {
        paused = true;
        home.classList.add('is-hovering');
        setActive(index);
      });
      tile.addEventListener('mouseleave', function () {
        paused = false;
        home.classList.remove('is-hovering');
      });
      tile.addEventListener('blur', function () {
        paused = false;
        home.classList.remove('is-hovering');
      });
    });

    home.dataset.timeoutId = String(window.setTimeout(function () {
      hasStarted = true;
      rotate();
    }, 900));

    home.dataset.timerId = String(window.setInterval(function () {
      if (hasStarted) rotate();
    }, 3000));
</script>
